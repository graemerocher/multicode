FROM node:22-bookworm-slim AS node
FROM docker:28-cli AS docker-cli
FROM eclipse-temurin:21-jdk AS jdk21

FROM ghcr.io/graalvm/native-image-community:25

ARG HOST_UID=1000
ARG HOST_GID=1000
ARG GH_VERSION=2.83.2
ARG CODEX_VERSION=0.121.0
ARG INSTALL_OPENCODE=1
ARG INSTALL_CODEX=0

COPY --from=node /usr/local/ /usr/local/
COPY --from=docker-cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=jdk21 /opt/java/openjdk /opt/jdks/jdk21

RUN set -eux; \
    microdnf install -y \
        bash \
        ca-certificates \
        curl \
        git \
        openssh-clients \
        procps-ng \
        rsync \
        shadow-utils \
        tar \
        tmux \
        unzip \
        xz \
        zstd; \
    microdnf clean all; \
    arch="$(uname -m)"; \
    case "${arch}" in \
        aarch64|arm64) gh_arch="arm64" ;; \
        x86_64|amd64) gh_arch="amd64" ;; \
        *) echo "unsupported architecture: ${arch}" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_${gh_arch}.tar.gz" \
      -o /tmp/gh.tar.gz; \
    tar -xzf /tmp/gh.tar.gz -C /tmp; \
    install "/tmp/gh_${GH_VERSION}_linux_${gh_arch}/bin/gh" /usr/local/bin/gh; \
    rm -rf /tmp/gh.tar.gz "/tmp/gh_${GH_VERSION}_linux_${gh_arch}"; \
    if [ "${INSTALL_OPENCODE}" = "1" ]; then \
        npm install -g opencode-ai; \
    fi; \
    if [ "${INSTALL_CODEX}" = "1" ]; then \
        npm install -g "@openai/codex@${CODEX_VERSION}"; \
    fi; \
    if ! getent group "${HOST_GID}" >/dev/null; then \
        groupadd --gid "${HOST_GID}" multicode; \
    fi; \
    mkdir -p /opt/jdks; \
    ln -s "${JAVA_HOME}" /opt/jdks/jdk25; \
    useradd \
        --uid "${HOST_UID}" \
        --gid "${HOST_GID}" \
        --create-home \
        --shell /bin/bash \
        multicode

ENV HOME=/home/multicode
ENV JDK21_HOME=/opt/jdks/jdk21
ENV JDK25_HOME=/opt/jdks/jdk25
ENV USER=multicode
ENV PATH=/usr/local/bin:${PATH}

USER multicode
WORKDIR /workspace
ENTRYPOINT []

CMD ["/bin/bash"]
